{
  "name": "agent-baba-d",
  "version": "1.12.0",
  "description": "Flexible AI inference CLI tool supporting local models and cloud APIs",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agent-baba-d": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepack": "npm run build"
  },
  "keywords": [
    "ai",
    "cli",
    "llm",
    "ollama",
    "gemini",
    "nim",
    "openrouter",
    "inference",
    "multi-agent",
    "code-generation",
    "devops"
  ],
  "license": "MIT",
  "author": "Dheeraj Sharma",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imdheerajKube/agent-baba-d.git"
  },
  "bugs": {
    "url": "https://github.com/imdheerajKube/agent-baba-d/issues"
  },
  "homepage": "https://github.com/imdheerajKube/agent-baba-d#readme",
  "engines": {
    "node": ">=21.7.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "inquirer": "^9.3.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.10",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.10"
  }
}
