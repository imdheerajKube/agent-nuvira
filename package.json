{
  "name": "agent-baba-d",
  "version": "1.0.0",
  "description": "Flexible AI inference CLI tool supporting local models and cloud APIs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agent-baba-d": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepack": "npm run build"
  },
  "keywords": [
    "ai",
    "cli",
    "llm",
    "ollama",
    "gemini",
    "nim",
    "openrouter",
    "inference"
  ],
  "license": "MIT",
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "inquirer": "^9.3.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/inquirer": "^9.0.10",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.10"
  }
}
