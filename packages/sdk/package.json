{
  "name": "@agent-nuvira/sdk",
  "version": "1.0.0",
  "description": "SDK for building custom agents for the agent-nuvira platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agent-nuvira",
    "agent",
    "sdk",
    "ai",
    "multi-agent"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0"
  },
  "peerDependencies": {
    "agent-nuvira": ">=1.14.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.11.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/imdheerajKube/agent-nuvira"
  },
  "publishConfig": {
    "access": "public"
  }
}
